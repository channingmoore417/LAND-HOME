# ============================================================
# Land Home Group — website env vars
# Copy to .env.local for local dev; set the same keys in Vercel.
# ============================================================

# --- Supabase (reads use the publishable/anon key; public-read RLS) ---
NEXT_PUBLIC_SUPABASE_URL=https://yqxxywdtdwlvsoofoird.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxx_or_legacy_anon_jwt

# --- Supabase service role (SERVER ONLY — used by /api/forms to write
#     leads/showing_requests/saved_searches, which are service-role-only).
#     Never expose to the browser. Set in Vercel as an encrypted env var. ---
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# --- Unified forms webhook. Every form on the site posts to /api/forms,
#     which writes to Supabase and then forwards the payload here.
#     Drop in the URL when you have it — no code changes needed. ---
FORMS_WEBHOOK_URL=

# --- On-demand revalidation. Shared secret the trestle-sync sends to
#     /api/revalidate so listing/price/status changes go live in seconds.
#     Server-only. Generate a long random string. ---
REVALIDATE_SECRET=your_long_random_secret_here

# --- Cloudinary photo proxy (optional). Set to your Cloudinary cloud name to
#     route expiring Trestle-signed photos through fetch delivery
#     (f_auto,q_auto). Leave blank to serve original MLS URLs directly. ---
NEXT_PUBLIC_CLOUDINARY_CLOUD=

# --- Site ---
NEXT_PUBLIC_SITE_URL=https://landhomegroup.com
